{
  "name": "szumrak",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Autonomous agent for performing narrow, highly verifiable tasks on target repositories.",
  "scripts": {
    "biome:check": "biome check .",
    "biome:ci": "biome ci --reporter=github",
    "biome:fix": "biome check --write .",
    "biome:format": "biome format .",
    "biome:format:fix": "biome format --write .",
    "biome:lint": "biome lint .",
    "biome:lint:fix": "biome lint --write .",
    "start": "tsx src/index.ts",
    "build": "docker build -t szumrak -f docker/Dockerfile .",
    "dev:run": "docker run --rm -e ANTHROPIC_API_KEY -e GH_TOKEN -e TASK -e REPO -e DRY_RUN=true -v $TARGET_REPO_PATH:/workspace szumrak",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.207",
    "@octokit/rest": "^22.0.1",
    "@t3-oss/env-core": "^0.13.11",
    "tsx": "^4.20.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@types/node": "^24.13.3",
    "@vitest/coverage-v8": "^4.1.10",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
