{
  "name": "szumrak",
  "version": "1.6.2",
  "private": true,
  "type": "module",
  "description": "Autonomous agent for performing narrow, highly verifiable tasks on target repositories.",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "biome:check": "biome check .",
    "biome:ci": "biome ci --reporter=github",
    "biome:fix": "biome check --write .",
    "biome:format": "biome format .",
    "biome:format:fix": "biome format --write .",
    "biome:lint": "biome lint .",
    "biome:lint:fix": "biome lint --write .",
    "start": "tsx src/index.ts",
    "dev:local": "node --env-file-if-exists=.env.local node_modules/tsx/dist/cli.mjs src/index.ts",
    "build": "docker build -t szumrak -f docker/Dockerfile .",
    "dev:run": "node --env-file-if-exists=.env.local node_modules/tsx/dist/cli.mjs scripts/dev-run.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.207",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/rest": "^22.0.1",
    "@t3-oss/env-core": "^0.13.11",
    "tsx": "^4.20.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@szum-tech/semantic-release-config": "^2.3.7",
    "@types/node": "^24.13.3",
    "@vitest/coverage-v8": "^4.1.10",
    "semantic-release": "^25.0.7",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
