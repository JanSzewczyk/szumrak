# Szumrak — environment variables
# Copy to .env and fill in. Never commit the real .env (it is gitignored).

# ─────────────────────────────────────────────────────────────────────────────
# Required
# ─────────────────────────────────────────────────────────────────────────────

# Claude API key, read by the Claude Agent SDK. Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# The task for the agent to perform, in natural language.
# Example: "Add a unit test for the formatDate helper"
TASK=

# ─────────────────────────────────────────────────────────────────────────────
# Required only when opening a PR (i.e. when DRY_RUN is not "true")
# ─────────────────────────────────────────────────────────────────────────────

# Target repository in "owner/repo" format. Used to open the PR.
REPO=your-org/your-repo

# GitHub Personal Access Token used to push the branch and open the PR.
# Use a minimal-scope token dedicated to the agent (not your default GITHUB_TOKEN).
GH_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# Optional
# ─────────────────────────────────────────────────────────────────────────────

# Path to the target repository the agent operates on. Inside the Docker image
# this is the mounted volume; on the host (Level 1 testing) point it at a local
# checkout. Default: /workspace
WORKSPACE_PATH=/workspace

# When "true", skip commit/push/PR and leave changes on disk only. Recommended
# for local testing. Any other value (or unset) performs the full commit + PR.
DRY_RUN=true

# Maximum number of agent turns (API round-trips) before stopping. Default: 30
MAX_TURNS=30

# Maximum wall-clock duration of a run in milliseconds before aborting.
# Default: 900000 (15 minutes)
MAX_DURATION_MS=900000

# Path for the structured JSONL run log (uploaded as a CI artifact).
# Default: <WORKSPACE_PATH>/agent-run.jsonl
AGENT_LOG_PATH=
